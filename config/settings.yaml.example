# FinMind API 設定
finmind:
  api_url: "https://api.finmindtrade.com/api/v4/data"
  api_token: ""  # 請填入你的 FinMind API Token

# 資料庫設定
database:
  url: "sqlite:///data/stock.db"

# 資料抓取預設參數
fetcher:
  default_start_date: "2020-01-01"
  # 預設關注的股票清單（台積電、鴻海、聯發科、台達電、中華電）
  watchlist:
    - "2330"
    - "2317"
    - "2454"
    - "2308"
    - "2412"

# 日誌等級
logging:
  level: "INFO"

# Anthropic Claude API 設定（AI 選股摘要功能，--ai-summary 旗標需要）
# 在 https://console.anthropic.com 取得 API Key
anthropic:
  api_key: ""                      # 請填入你的 Anthropic API Key
  model: "claude-sonnet-4-6"       # 可選：claude-opus-4-6（最強）/ claude-sonnet-4-6（預設）/ claude-haiku-4-5-20251001（最快）

# Discord Webhook 通知設定
# 在 Discord 頻道設定 → 整合 → Webhook → 建立 Webhook，複製 URL
discord:
  webhook_url: ""              # 填入你的 Discord Webhook URL
  username: "台股量化系統"       # Webhook 顯示名稱
  enabled: true                # 設為 false 可暫時停用通知

# 量化參數（可選 — 未設定則使用程式內建預設值）
# quant:
#   trading_cost:
#     commission_rate: 0.001425   # 手續費 0.1425%
#     tax_rate: 0.003             # 交易稅 0.3%（賣出時）
#     slippage_rate: 0.0005       # 滑價 0.05%
#     slippage_impact_coeff: 0.5  # 動態滑價衝擊係數
#     liquidity_participation_limit: 0.05  # 流動性約束（單筆 ≤ 當日量 × 此比例）
#   atr_multiplier:
#     bull_stop: 1.5              # 多頭止損 ATR 倍數
#     bull_target: 3.0            # 多頭目標 ATR 倍數
#     sideways_stop: 2.0          # 盤整止損
#     sideways_target: 2.5        # 盤整目標
#     bear_stop: 2.5              # 空頭止損
#     bear_target: 2.0            # 空頭目標
#     crisis_stop: 3.0            # 危機止損
#     crisis_target: 1.5          # 危機目標
#   score_threshold:
#     bull: 0.45                  # 多頭最低評分門檻
#     sideways: 0.50
#     bear: 0.55
#     crisis: 0.60
